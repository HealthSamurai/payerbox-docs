    {
      "resource": {
        "resourceType": "AccessPolicy",
        "id": "admin-api",
        "engine": "matcho",
        "description": "Scoped access for admin API client (sessions, orgs, clients, users, tos/privacy)",
        "matcho": {
          "client": {
            "id": "admin-api"
          },
          "$one-of": [
            {
              "params": {
                "resource/type": "Session"
              },
              "operation": {
                "id": {
                  "$one-of": [
                    "FhirCreate",
                    "FhirSearch",
                    "FhirRead",
                    "FhirUpdate",
                    "FhirPatch"
                  ]
                }
              }
            },
            {
              "params": {
                "resource/type": "Organization"
              },
              "operation": {
                "id": {
                  "$one-of": [
                    "FhirSearch",
                    "FhirRead"
                  ]
                }
              }
            },
            {
              "params": {
                "resource/type": "Client"
              },
              "operation": {
                "id": {
                  "$one-of": [
                    "FhirSearch",
                    "FhirRead"
                  ]
                }
              }
            },
            {
              "params": {
                "resource/type": "User"
              },
              "operation": {
                "id": "FhirRead"
              }
            },
            {
              "params": {
                "resource/type": "DocumentReference",
                "resource/id": {
                  "$one-of": [
                    "smartbox-tos",
                    "smartbox-privacy"
                  ]
                }
              },
              "operation": {
                "id": {
                  "$one-of": [
                    "FhirRead",
                    "FhirUpdate",
                    "FhirCreate"
                  ]
                }
              }
            }
          ]
        }
      },
      "request": {
        "method": "PUT",
        "url": "AccessPolicy/admin-api"
      }
    },
